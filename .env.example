# ============================================
# HSQ Portal - Variáveis de Ambiente
# ============================================
# Copie este arquivo para .env e preencha os valores

# PostgreSQL
POSTGRES_USER=hsq_admin
POSTGRES_PASSWORD=SUA_SENHA_AQUI
POSTGRES_DB=hsq_portal

# API
DATABASE_URL=postgresql://hsq_admin:SUA_SENHA_AQUI@hsq-db:5432/hsq_portal
JWT_SECRET=gere-um-secret-seguro-aqui
CORS_ORIGIN=*
PORT=4080
HSQ_WEB_PORT=3080

# Traccar (servidor de rastreamento)
TRACCAR_URL=https://traccar.seudominio.com.br
TRACCAR_ADMIN_EMAIL=admin@seudominio.com
TRACCAR_ADMIN_PASSWORD=SUA_SENHA_TRACCAR_AQUI

# Seed inicial do painel admin
ADMIN_SEED_EMAIL=admin@seudominio.com
ADMIN_SEED_PASSWORD=gere-uma-senha-inicial-aqui
